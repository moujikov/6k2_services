POSTFIX_myhostname=smtp.6k2.ru
POSTFIX_mydomain=6k2.ru
POSTFIX_myorigin=6k2.ru
POSTFIX_bounce_notice_recipient=mailer@6k2.ru
POSTFIX_smtpd_sasl_auth_enable=yes
POSTFIX_smtpd_sasl_security_options=noanonymous
POSTFIX_smtpd_relay_restrictions=permit_sasl_authenticated,reject
POSTFIX_smtpd_hide_client_session=yes

SASL_Passwds=/etc/postfix/sasl/sasl_passwds

OPENDKIM_DOMAINS=6k2.ru=mailing-list
